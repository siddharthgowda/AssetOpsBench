# ── CouchDB (IoTAgent server) ────────────────────────────────────────────────
COUCHDB_URL=http://localhost:5984
COUCHDB_USERNAME=admin
COUCHDB_PASSWORD=password
IOT_DBNAME=chiller
WO_DBNAME=workorder

# ── IBM WatsonX (plan-execute runner) ────────────────────────────────────────
WATSONX_APIKEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com   # optional

# ── LiteLLM (plan-execute runner) ────────────────────────────────────────────
LITELLM_API_KEY=
LITELLM_BASE_URL=

# ── Battery server ───────────────────────────────────────────────────────────
BATTERY_DBNAME=battery
BATTERY_MODEL_WEIGHTS_DIR=src/servers/battery/artifacts/weights
BATTERY_NORMS_DIR=src/servers/battery/artifacts/norms
BATTERY_DATA_DIR=external/battery/nasa
# Which cells load into CouchDB. Default is the 14 cell subset. Set to "all" to load all 34.
BATTERY_CELL_SUBSET=B0005,B0006,B0007,B0018,B0025,B0029,B0030,B0033,B0034,B0036,B0038,B0054,B0055,B0056
# BATTERY_MODEL_ID=                  # optional; inherits FMSR_MODEL_ID if unset

# Battery optimization toggles. Defaults are all on. Set any to 0 to turn that one off.
BATTERY_FETCH_WORKERS=4         # how many threads parallel CouchDB fetch uses
BATTERY_PARALLEL_FETCH=1        # parallel CouchDB fetch in predict_rul_batch
BATTERY_GRAPH_PRECOMPILE=1      # precompile the TF graphs once at boot
BATTERY_BATCHED_PREDICT=1       # batched TF predict across cells in predict_rul_batch
BATTERY_DISK_CACHE=1            # cache predict outputs to .npz so we can skip TF on repeat calls
